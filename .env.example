# Upstash Redis（Vercel 後台 → Storage → Upstash Redis 可一鍵連結）
KV_REST_API_URL=
KV_REST_API_TOKEN=

# 分析後台 /admin 登入密鑰
ADMIN_SECRET=your-strong-secret-here

# Google Analytics 4（流量／漏斗；遊戲選項與裁決仍走 Redis）
# 1. analytics.google.com 建立 GA4 資源 → 取得 G-XXXXXXXXXX
# 2. Vercel → Settings → Environment Variables 填入下方 ID
# 3. 預設僅 production 啟用；本地測試設 GA_ENABLED=true
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GA_ENABLED=
